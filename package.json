{
  "name": "@thanh-libs/utils",
  "version": "0.0.7-alpha.0",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@thanh-libs/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major"
  },
  "devDependencies": {
    "@types/node": "20.19.9",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "vite": "^7.0.0",
    "vitest": "^4.1.0"
  },
  "files": [
    "dist",
    "LICENSE",
    "!**/*.tsbuildinfo"
  ],
  "standard-version": {
    "scripts": {
      "prerelease": "node ../../node_modules/vitest/vitest.mjs run --passWithNoTests",
      "postbump": "node ../../node_modules/typescript/bin/tsc --project tsconfig.lib.json"
    }
  }
}
